<div class="d-flex justify-content-center">
  <h1 class="text-center mt-4" style="font-weight: bold;"><%= @pet.petname%>'s Trackers</h1>
</div>

<div class="d-flex float-sm-center justify-content-center mb-4">
  <%= link_to "#{image_tag('icon_add.png', width:'18px', height: '18px')} Adding #{@pet.petname.capitalize}'s New Record".html_safe, new_pet_tracker_path %>
</div>

<div class="d-flex digg_pagination justify-content-center">
  <div class="page_info">
    <%= page_entries_info @trackers %>
  </div>
</div>

<div class="d-flex digg_pagination justify-content-center mb-4">
  <%= will_paginate @trackers, :container => false %>
</div>

<%= render 'tracker' %>

<div class="mb-5">
  <%= column_chart [{name: "Wet Total Ate Amount", data: @pet.trackers.where(food_type: "Wet").where.not(total_ate_amount: nil).group(:date).sum(:total_ate_amount)}, 
    {name: "Dry Total Ate Amount", data: @pet.trackers.where(food_type: "Dry").where.not(total_ate_amount: nil).group(:date).sum(:total_ate_amount)},
    {name: "Other Total Ate Amount", data: @pet.trackers.where(food_type: "Other").where.not(total_ate_amount: nil).group(:date).sum(:total_ate_amount)}], stacked: true %>
</div>

<div class="d-flex digg_pagination justify-content-center">
  <div class="page_info">
    <%= page_entries_info @trackers %>
  </div>
</div>
<div class="d-flex digg_pagination justify-content-center mb-5">
  <%= will_paginate @trackers, :container => false %>
</div>
