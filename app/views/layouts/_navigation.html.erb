<nav class="navbar navbar-expand-lg bg-body-tertiary">
  <div class="container-fluid">
    <ul class="navbar-nav">
      <li class="nav-item">
        <%= link_to " Home", root_path, class: "nav-link active bi bi-house" %>
      </li>
      <li class="nav-item">
        <%= link_to " About", about_path, class: "nav-link active bi bi-feather" %>
      </li>
      <li class="nav-item">
        <a class="nav-link active" aria-current="page" href="/started"><i class="bi bi-book"></i> Get Started</a>
      </li>

      <% if authenticated? %>
        <li class="nav-item dropdown">
          <a class="nav-link dropdown-toggle" role="button" data-bs-toggle="dropdown" aria-expanded="false"><i class="bi bi-person"></i> <%= Current.user.username.capitalize%>'s Profile</a>
          <ul class="dropdown-menu">
            <%= link_to " Edit #{Current.user.username.capitalize}'s Profile", edit_user_path(Current.user), class: "dropdown-item bi-pencil" %>
            <%= link_to " View #{Current.user.username.capitalize}'s Profile", user_path(Current.user), class: "dropdown-item bi-person-vcard" %>
            <%= link_to " #{Current.user.username.capitalize}'s Pet Lists", pets_path, class: "dropdown-item bi-bookmark-heart" %>
            <%= link_to " Delete #{Current.user.username.capitalize}'s Profile", user_path(Current.user), class: "dropdown-item bi-trash3", style: "color: #F40B2E !important;", data: {"turbo-confirm":  "Are you sure to delete this user #{Current.user.username.capitalize}'s account? The user and associated trackers will all gone..", "turbo-method": :delete } %>
          </ul>
        </li>

        <li class="nav-item dropdown">
          <a class="nav-link dropdown-toggle" role="button" data-bs-toggle="dropdown" aria-expanded="false"> 😸 Cats' Dashboard</a>
          <ul class="dropdown-menu">
            <%= link_to " Add A Cat", new_pet_path, class: "dropdown-item bi-plus-circle-dotted" %>
            <% Current.user.pets.select(&:persisted?).each do |pet| %>
                <%= link_to " View #{pet.petname.capitalize}'s Profile", pet_path(pet), class: "dropdown-item bi-eye" %>
            <% end %>
          </ul>
        </li>

        <li class="nav-item dropdown">
          <a class="nav-link dropdown-toggle" role="button" data-bs-toggle="dropdown" aria-expanded="false"><i class="bi bi-database"></i> Dry Food Storage</a>
          <ul class="dropdown-menu">
            <%= link_to " Add Dry Food", new_dry_food_path, class: "dropdown-item bi-database-fill-add" %>
            <%= link_to " Dry Food Storage List", dry_foods_path, class: "dropdown-item bi-fork-knife" %>
          </ul>
        </li>

        <li class="nav-item dropdown">
          <a class="nav-link dropdown-toggle" role="button" data-bs-toggle="dropdown" aria-expanded="false"><i class="bi bi-clipboard-data-fill"></i> Tracker's Dashboard</a>
          <ul class="dropdown-menu">
              <% Current.user.pets.select(&:persisted?).each do |pet| %>
                <%= link_to " #{pet.petname.capitalize}'s Trackers", pet_trackers_path(pet), class: "dropdown-item bi-bar-chart-line"%>
              <% end %>
          </ul>
        </li>

        <li class="nav-item dropdown">
          <a class="nav-link dropdown-toggle" role="button" data-bs-toggle="dropdown" aria-expanded="false"><i class="bi bi-search-heart"></i> Favorite Food List</a>
          <ul class="dropdown-menu">
            <% Current.user.pets.select(&:persisted?).each do |pet| %>
              <li>
                <%= link_to "View #{pet.petname.capitalize}'s Favorite", "/pets/#{pet.id}/favorites", class: "dropdown-item bi-search" %>
              </li>
            <% end %>
          </ul>
        </li>

        <li class="nav-item">
          <%= button_to 'Log Out', session_path, class: "nav-link bi bi-person-walking", method: :delete %>
        </li>
      <% else %>
        <li class="nav-item">
          <%= link_to 'Log In', new_session_path, class:"nav-link" %>
        </li>
        <li class="nav-item">
          <%= link_to 'Sign Up', new_registrations_path, class:"nav-link" %>
        </li>
      <% end %>
    </ul>

    <div class="d-flex justify-content-end pe-3">
      <ul class="navbar-nav">
        <% I18n.available_locales.each do |locale| %>
          <li><%= link_to locale_to_word_flag(locale), url_for(locale: locale), class: "nav-link active #{(locale == I18n.locale ? 'border-bottom' : '')}" %></li>
        <% end %>
      </ul>
    </div>
  </div>
</nav>