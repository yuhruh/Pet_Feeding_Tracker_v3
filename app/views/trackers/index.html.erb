<div class="d-flex justify-content-center">
  <h1 class="text-center mt-4" style="font-weight: bold;"><%= t('trackers.index.title', petname: @pet.petname) %></h1>
</div>

<div class="d-flex float-sm-center justify-content-center mb-4">
  <%= link_to "#{image_tag('icon_add.png', width:'18px', height: '18px')} #{t('trackers.index.add', petname: @pet.petname.capitalize)}".html_safe, new_pet_tracker_path %>
</div>

<div class="container mb-4">
  <%= form_with(url: pet_trackers_path(@pet), method: :get, local: true) do |form| %>
    <div class="row justify-content-center">
      <div class="col-md-4">
        <%= form.label :brand, t('trackers.index.filter_by_brand'), class: "form-label" %>
        <%= form.text_field :brand, value: params[:brand], class: "form-control" %>
      </div>
      <div class="col-md-4">
        <%= form.label :description, t('trackers.index.filter_by_description'), class: "form-label" %>
        <%= form.text_field :description, value: params[:description], class: "form-control" %>
      </div>
      <div class="col-md-2 align-self-end">
        <%= form.submit t('trackers.index.filter'), class: "btn btn-primary" %>
      </div>
    </div>
  <% end %>
</div>

<fieldset>
  <%= link_to "#{image_tag('download.png', width:'25px', height: '25px')} #{t('trackers.index.export_csv')}".html_safe, pet_trackers_path(format: :csv), class:"d-flex justify-content-center mb-3", style: "color: #515a5a; font-weight: bold;", download: [@pet.petname.capitalize, "trackers", Date.today].join('_') %>
</fieldset>

<div class="d-flex digg_pagination justify-content-center">
  <div class="page_info">
    <%= page_entries_info @trackers %>
  </div>
</div>

<div class="d-flex digg_pagination justify-content-center mb-4">
  <%= will_paginate @trackers, :container => false %>
</div>

<%= render 'tracker' %>

<div class="mb-5">
  <%= column_chart [{name: t('trackers.index.wet_total_ate_amount'), data: @pet.trackers.where(food_type: "Wet").where.not(total_ate_amount: nil).group(:date).sum(:total_ate_amount)}, 
    {name: t('trackers.index.dry_total_ate_amount'), data: @pet.trackers.where(food_type: "Dry").where.not(total_ate_amount: nil).group(:date).sum(:total_ate_amount)},
    {name: t('trackers.index.other_total_ate_amount'), data: @pet.trackers.where(food_type: "Other").where.not(total_ate_amount: nil).group(:date).sum(:total_ate_amount)}], stacked: true %>
</div>

<div class="d-flex digg_pagination justify-content-center">
  <div class="page_info">
    <%= page_entries_info @trackers %>
  </div>
</div>
<div class="d-flex digg_pagination justify-content-center mb-5">
  <%= will_paginate @trackers, :container => false %>
</div>

<h2 class="text-center mt-4" style="font-weight: bold;"><%= t('trackers.index.weight_chart_title', petname: @pet.petname.capitalize) %></h2>
<%= line_chart @pet.trackers.group(:date).sum(:weight) %>
