<h1 class="text-center mt-4" style="font-weight: bold;">Editing <%= @pet.petname.capitalize %>'s Eating Record</h1>

<div class="container">
  <%= form_with(model: [@pet, @tracker]) do |form| %>
    <div class="d-flex justify-content-center">
       <%= render 'shared/errors', obj: @tracker %>
    </div>

    <div class="mb-3 row justify-content-center">
      <%= form.label 'Date', class: "col-sm-2 col-form-label text-start required", style: "color: #515a5a; font-weight: bold" %>
      <div class="col-sm-5">
        <%= form.date_field :date, value: @tracker.date, class: "form-control" %>
      </div>
    </div>

    <div class="mb-3 row justify-content-center">
      <%= form.label "Feed Time", class: "col-sm-2 col-form-label text-start required", style: "color: #515a5a; font-weight: bold" %>
      <div class="col-sm-5">
        <fieldset disabled>
          <%= form.time_field :feed_time, value: @tracker.feed_time.strftime("%H:%M"), class: "form-control" %>
        </fieldset>
      </div>
    </div>

    <div class="mb-3 row justify-content-center">
      <%= form.label "Come back to Eat Time", class: "col-sm-2 col-form-label text-start optional", style: "color: #515a5a; font-weight: bold" %>
      <div class="col-sm-5">
        <%= form.text_field :come_back_to_eat_time, class: "form-control", placeholder: "Please use ',' as a separations. Ex: 07:45, 10:33,..." %>
      </div>
    </div>

    <div class="mb-3 row justify-content-center">
      <%= form.label :brand, class: "col-sm-2 col-form-label required", style: "color: #515a5a; font-weight: bold" %>
      <div class="col-sm-5">
        <%= form.text_field :brand, class: "form-control", value: @tracker.brand  %>
      </div>
    </div>

    <div class="mb-3 row justify-content-center">
      <%= form.label :description, class: "col-sm-2 col-form-label required", style: "color: #515a5a; font-weight: bold" %>
      <div class="col-sm-5">
        <%= form.text_field :description, class: "form-control", value: @tracker.description  %>
        <div id="descriptionHelpBlock" class="form-text">"Input food's flavor or serial number for easy to track"</div>
      </div>
    </div>


    <div class="mb-3 row justify-content-center">
      <%= form.label :left_amount, class: "col-sm-2 col-form-label required", style: "color: #515a5a; font-weight: bold" %>
      <div class="col-sm-5">
        <%= form.number_field :left_amount, step: :any, class: "form-control floatingInput", required: true, max: @tracker.amount, min: 0 %>
        <div id="amountHelpBlock" class="form-text">"Input number/float number only without unit"</div>
      </div>
    </div>

    <div class="mb-3 row justify-content-center">
      <%= form.label :love, class: "col-sm-2 col-form-label required", style: "color: #515a5a; font-weight: bold" %>
      <div class="col-sm-5">
        <%= form.select :love, ["❤️‍🔥 Love it So Much", "🔺 So So", "❌ No!!!"], { :include_blank => "Does he/she love this food?" }, class: "form-control", required: true %>
      </div>
    </div>

    <div class="mb-3 row justify-content-center">
      <%= form.label "Weight(Kg)", class: "col-sm-2 col-form-label optional", style: "color: #515a5a; font-weight: bold" %>
      <div class="col-sm-5">
        <%= form.number_field :weight, step: :any, class: "form-control floatingInput", placeholder: "Please enter a number of range 0~100", max: 100, min: 0.0 %>
        <div id="amountHelpBlock" class="form-text">"You can weigh Cat's Weight every 2~3 weeks, and record it."</div>
      </div>
    </div>

    <div class="row mb-3 justify-content-center">
        <%= form.label :note, class: "col-sm-2 col-form-label optional", style: "color: #515a5a; font-weight: bold" %>
        <div class="col-sm-5">
          <%= form.text_field :note, class: "form-control floatingInput" %>
          <div id="noteHelpBlock" class="form-text">"You can add whatever you want to record, such as when the cat vomit 🤮"</div>
        </div>
      </div>

    <div class="d-flex justify-content-center mb-4">
      <%= form.submit(@tracker.new_record? ? 'Add a new record' : "Update", class: "btn", style: "color: #515a5a; font-weight: bold; background-color: #d5dbdb") %>
    </div>
  <% end %>
</div>