<div class="container text-center mt-2 mb-2">
  <div class="px-6 py-4 border border-dark-subtle rounded-3">

    <h1 class="text-center mt-4" style="font-weight: bold;"><%= t('trackers.favorite_food.title', petname: @pet.petname.capitalize) %></h1>

    <div class="d-flex justify-content-center mb-4">
      <div class="form-group d-flex align-items-center">
        <label for="food-type-filter" class="me-2"><%= t('trackers.favorite_food.filter') %></label>
        <select class="form-select" id="food-type-filter" style="width: auto;">
          <option value="all"><%= t('trackers.favorite_food.all') %></option>
          <option value="Dry"><%= t('trackers.favorite_food.dry_food') %></option>
          <option value="Wet"><%= t('trackers.favorite_food.wet_food') %></option>
        </select>
      </div>
    </div>

    <% if @pet.trackers.empty? %>
      <h3 class="text-center mt-4"><%= t('trackers.favorite_food.no_record', petname: @pet.petname.capitalize) %></h3>
    <% else %>    
      <table class="table table-bordered mx-3" style="width:98%">
        <thead class="table-dark">
          <tr class='text-center justify-content-center'>
            <th scope="col"><%= t('trackers.favorite_food.number') %></th>
            <th scope="col"><%= t('trackers.favorite_food.food_type') %></th>
            <th scope="col"><%= t('trackers.favorite_food.brand') %></th>
            <th scope="col"><%= t('trackers.favorite_food.description') %></th>
            <th scope="col"><%= t('trackers.favorite_food.result') %></th>
            <th scope="col"><%= t('trackers.favorite_food.favorite_score') %></th>
          </tr>
        </thead>
        <tbody class="table-group-divider" id="trackers-body">
          <% @pet.trackers.order(favorite_score: 'desc').each_with_index do |pet_tracker, idx| %>
            <% if pet_tracker.result.present? %>
              <tr class='text-center justify-content-center' data-food-type="<%= pet_tracker.food_type %>">
                <th scope="row"><%= idx+1 %></th>
                <td><%= pet_tracker.food_type.capitalize %></td>
                <td><%= pet_tracker.brand %></td>
                <td><%= pet_tracker.description %></td>
                <td><%= pet_tracker.result %></td>
                <td><%= pet_tracker.favorite_score %></td>
              </tr>
            <% end %>
          <% end %>
        </tbody>
      </table>
    <% end %>
  </div>
</div>


<script>
  document.addEventListener('DOMContentLoaded', function() {
    const filterDropdown = document.getElementById('food-type-filter');
    const tableBody = document.getElementById('trackers-body');

    if (filterDropdown && tableBody) {
      filterDropdown.addEventListener('change', function() {
        const selectedFoodType = this.value;
        const rows = tableBody.querySelectorAll('tr');

        rows.forEach(row => {
          const rowFoodType = row.getAttribute('data-food-type');
          if (selectedFoodType === 'all' || selectedFoodType === rowFoodType) {
            row.style.display = '';
          } else {
            row.style.display = 'none';
          }
        });
      });
    }
  });
</script>