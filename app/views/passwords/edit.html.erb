<div class="container text-center">
  <h1 class="mb-3"><%= t(".title") %> 🐾🐾</h1>

  <%= form_with url: password_path, method: :patch do |form| %>
      <div class="row mb-3 justify-content-center">
        <%= form.label 'Password', t(".password"), class: "col-sm-3 col-form-label text-start required", style: "color: #515a5a; font-weight: bold" %>
        <div class="col-sm-3">
          <%= form.password_field :password, required: true, autocomplete: "new-password", placeholder: t(".password_placeholder"), class: "form-control mb-3" %>
        </div>
      </div>

      <div class="row mb-3 justify-content-center">
        <%= form.label 'Password Confirmation', t(".password_confirmation"), class: "col-sm-3 col-form-label text-start required", style: "color: #515a5a; font-weight: bold" %>
        <div class="col-sm-3">
          <%= form.password_field :password_confirmation, required: true, autocomplete: "new-password", placeholder: t(".password_confirmation_placeholder"), class: "form-control mb-3" %>
        </div>
      </div>
      <div class="d-flex justify-content-center">
        <%= form.submit t(".submit"), class: "btn mb-3", style: "color: #515a5a; font-weight: bold; background-color: #d5dbdb" %>
      </div>
  <% end %>
</div>

